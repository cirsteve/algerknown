{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://algerknown.dev/schemas/summary.schema.json",
  "title": "Algerknown Summary",
  "description": "A topic summary aggregating learnings, decisions, and artifacts",
  "type": "object",
  "required": ["id", "type", "topic", "status", "summary"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique identifier for this summary",
      "pattern": "^[a-z0-9-]+$"
    },
    "type": {
      "type": "string",
      "const": "summary"
    },
    "topic": {
      "type": "string",
      "description": "Human-readable topic name"
    },
    "date_range": {
      "$ref": "#/$defs/dateRange"
    },
    "status": {
      "$ref": "#/$defs/status"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "summary": {
      "type": "string",
      "description": "Brief description of the topic"
    },
    "learnings": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/learning"
      }
    },
    "decisions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/decision"
      }
    },
    "artifacts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/artifact"
      }
    },
    "open_questions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "resources": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/resource"
      }
    },
    "links": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/link"
      }
    },
    "last_ingested": {
      "type": "string",
      "format": "date",
      "description": "Date this entry was last ingested into the RAG system (auto-populated)"
    },
    "dossier": {
      "$ref": "#/$defs/dossier"
    }
  },
  "$defs": {
    "dateRange": {
      "type": "object",
      "required": ["start"],
      "properties": {
        "start": {
          "type": "string",
          "pattern": "^\\d{4}(-\\d{2})?(-\\d{2})?$",
          "description": "Start date (YYYY, YYYY-MM, or YYYY-MM-DD)"
        },
        "end": {
          "type": "string",
          "pattern": "^\\d{4}(-\\d{2})?(-\\d{2})?$",
          "description": "End date (YYYY, YYYY-MM, or YYYY-MM-DD)"
        }
      }
    },
    "status": {
      "type": "string",
      "enum": ["active", "archived", "reference", "blocked", "planned"],
      "description": "Current status of the topic"
    },
    "learning": {
      "type": "object",
      "required": ["insight"],
      "properties": {
        "insight": {
          "type": "string",
          "description": "The key learning or insight"
        },
        "context": {
          "type": "string",
          "description": "How this was discovered"
        },
        "relevance": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "IDs of related entries"
        }
      }
    },
    "decision": {
      "type": "object",
      "required": ["decision"],
      "properties": {
        "decision": {
          "type": "string",
          "description": "What was decided"
        },
        "rationale": {
          "type": "string",
          "description": "Why this decision was made"
        },
        "trade_offs": {
          "type": "string",
          "description": "What was sacrificed or risked"
        },
        "date": {
          "type": "string",
          "format": "date"
        },
        "superseded_by": {
          "type": "string",
          "description": "ID of decision that replaced this one"
        }
      }
    },
    "artifact": {
      "type": "object",
      "required": ["path"],
      "properties": {
        "repo": {
          "type": "string",
          "description": "Repository URL or name"
        },
        "path": {
          "type": "string",
          "description": "Path within the repo"
        },
        "notes": {
          "type": "string"
        },
        "commit": {
          "type": "string",
          "description": "Specific commit hash"
        }
      }
    },
    "resource": {
      "type": "object",
      "required": ["url"],
      "properties": {
        "url": {
          "type": "string",
          "format": "uri"
        },
        "title": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "link": {
      "type": "object",
      "required": ["id", "relationship"],
      "properties": {
        "id": {
          "type": "string",
          "description": "ID of the linked entry"
        },
        "relationship": {
          "$ref": "#/$defs/relationship"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "relationship": {
      "type": "string",
      "enum": [
        "evolved_into",
        "evolved_from",
        "informs",
        "informed_by",
        "part_of",
        "contains",
        "blocked_by",
        "blocks",
        "supersedes",
        "superseded_by",
        "references",
        "referenced_by",
        "depends_on",
        "dependency_of",
        "enables",
        "enabled_by"
      ],
      "description": "How entries relate to each other. Bidirectional pairs allow expressing relationships from either direction."
    },
    "dossier": {
      "type": "object",
      "description": "Canonical, versioned, operator-reviewed project dossier for downstream Scout consumption",
      "required": ["project_key", "last_reviewed", "reviewer", "evidence", "facts", "resources", "prohibitions", "known_gaps"],
      "additionalProperties": false,
      "properties": {
        "project_key": {
          "type": "string",
          "pattern": "^[a-z0-9-]+$",
          "description": "Kebab-case key matching the Scout project key"
        },
        "last_reviewed": {
          "type": "string",
          "format": "date",
          "description": "ISO YYYY-MM-DD date of last operator review; must not be in the future"
        },
        "reviewer": {
          "$ref": "#/$defs/dossierReviewer"
        },
        "evidence": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/dossierEvidence"
          }
        },
        "facts": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/dossierFact"
          }
        },
        "resources": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/dossierResource"
          }
        },
        "prohibitions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/dossierProhibition"
          }
        },
        "known_gaps": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/dossierKnownGap"
          }
        }
      }
    },
    "dossierReviewer": {
      "type": "object",
      "required": ["id", "display_name"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "description": "Stable reviewer identifier"
        },
        "display_name": {
          "type": "string",
          "description": "Human-readable reviewer name"
        }
      }
    },
    "dossierEvidence": {
      "type": "object",
      "required": ["id", "kind", "locator", "immutable_ref"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^evidence-[a-z0-9-]+$",
          "description": "Stable kebab-case id prefixed evidence-"
        },
        "kind": {
          "type": "string",
          "description": "Category of evidence (e.g. git-commit, arxiv-paper, web-archive)"
        },
        "locator": {
          "type": "string",
          "description": "Human-readable location or citation"
        },
        "immutable_ref": {
          "type": "string",
          "description": "Pinned reference: git commit/blob hash, content digest, versioned document id, or archived snapshot identifier"
        }
      }
    },
    "dossierFact": {
      "type": "object",
      "required": ["id", "claim", "status", "safe_phrasings", "evidence_ids"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^fact-[a-z0-9-]+$",
          "description": "Stable kebab-case id prefixed fact-"
        },
        "claim": {
          "type": "string",
          "description": "Canonical human-readable meaning of the fact"
        },
        "status": {
          "type": "string",
          "enum": ["shipped", "experimental", "planned", "deprecated"],
          "description": "Deployment status of the fact"
        },
        "safe_phrasings": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "uniqueItems": true,
          "description": "Finite set of approved exact phrasings; only listed phrasings may be used"
        },
        "evidence_ids": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "description": "References to dossier evidence records"
        }
      }
    },
    "dossierResource": {
      "type": "object",
      "required": ["id", "label", "canonical_url", "purpose", "evidence_ids"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^res-[a-z0-9-]+$",
          "description": "Stable kebab-case id prefixed res-"
        },
        "label": {
          "type": "string",
          "description": "Human-readable label"
        },
        "canonical_url": {
          "type": "string",
          "pattern": "^https?://[^#]+$",
          "description": "Absolute http/https URL with no fragment; must be unique after URL canonicalization"
        },
        "purpose": {
          "type": "string",
          "description": "Why this resource is included"
        },
        "evidence_ids": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "description": "References to dossier evidence records"
        }
      }
    },
    "dossierProhibition": {
      "type": "object",
      "required": ["id", "forbidden_phrasings", "evidence_ids"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^proh-[a-z0-9-]+$",
          "description": "Stable kebab-case id prefixed proh-"
        },
        "exact_phrase": {
          "type": "string",
          "description": "Exact literal string to match"
        },
        "normalized_phrase": {
          "type": "string",
          "description": "Phrase matched after whitespace normalization and case folding"
        },
        "regex": {
          "type": "string",
          "description": "Regular expression pattern; only flags i, m, s are permitted"
        },
        "flags": {
          "type": "string",
          "description": "Optional regex flags; only i, m, s are supported"
        },
        "forbidden_phrasings": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "description": "Human-readable examples of forbidden text"
        },
        "evidence_ids": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "description": "References to dossier evidence records"
        },
        "resource_ids": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Optional references to dossier resources (res-* ids only)"
        }
      }
    },
    "dossierKnownGap": {
      "type": "object",
      "required": ["id", "question"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^gap-[a-z0-9-]+$",
          "description": "Stable kebab-case id prefixed gap-"
        },
        "question": {
          "type": "string",
          "description": "The open question representing the gap"
        },
        "related_fact_ids": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Optional references to related facts within the dossier"
        },
        "related_resource_ids": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Optional references to related resources within the dossier"
        }
      }
    }
  }
}
