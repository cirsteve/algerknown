{
  "name": "@algerknown/governed",
  "version": "0.1.0",
  "description": "Application-independent governed domain, ports, and write orchestrator",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc && mkdir -p dist/sqlite/migrations && cp src/sqlite/migrations/*.sql dist/sqlite/migrations/",
    "dev": "tsc --watch",
    "test": "vitest run",
    "lint": "eslint src/"
  },
  "keywords": [
    "algerknown",
    "governed",
    "domain",
    "policy"
  ],
  "license": "MIT",
  "dependencies": {
    "ajv": "^8.12.0",
    "ajv-formats": "^2.1.1",
    "better-sqlite3": "^11.10.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  }
}
