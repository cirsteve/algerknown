{
  "name": "@algerknown/governed",
  "version": "0.1.0",
  "description": "Application-independent governed domain, ports, and write orchestrator",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./adapters/algerknown": {
      "types": "./dist/adapters/algerknown/index.d.ts",
      "default": "./dist/adapters/algerknown/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "lint": "eslint src/"
  },
  "keywords": [
    "algerknown",
    "governed",
    "domain",
    "policy"
  ],
  "license": "MIT",
  "dependencies": {
    "@algerknown/core": "*",
    "ajv": "^8.12.0",
    "ajv-formats": "^2.1.1",
    "yaml": "^2.3.4"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  }
}
