# Algerknown Environment Configuration
# Copy this file to .env and fill in your values

# ============================================================
# RAG Backend (Python/FastAPI)
# Required for AI-powered query and ingest features
# ============================================================

# OpenAI API key (for embeddings)
OPENAI_API_KEY=sk-...

# Anthropic API key (for LLM synthesis when using anthropic provider)
ANTHROPIC_API_KEY=sk-ant-...

# LLM Configuration
# Provider options: "anthropic" (cloud) or "dispatch" (local via smithers)
LLM_QUERY_PROVIDER=anthropic
LLM_QUERY_MODEL=claude-sonnet-4-20250514
LLM_INGEST_PROVIDER=anthropic
LLM_INGEST_MODEL=claude-sonnet-4-20250514

# Smithers dispatch settings (required when using dispatch provider)
# Set to wherever the dispatch service is running
DISPATCH_URL=http://localhost:8900
DISPATCH_TIMEOUT=300

# Use local embeddings (sentence-transformers) instead of OpenAI
# Set to true to avoid OpenAI API costs or if you have quota issues
USE_LOCAL_EMBEDDINGS=false

# Content directory path (relative to rag-backend or absolute)
CONTENT_DIR=../content-agn

# Jig SqliteStore path (file, not directory). MEMORY_DB_PATH is the
# canonical name post-phase-13; the legacy CHROMA_DB_DIR still resolves
# as a fallback during the rollout window.
MEMORY_DB_PATH=./memory_db/memory.db
TRACER_DB_PATH=./memory_db/traces.db

# RAG server host and port
# Loopback by default; see docs/springfield-deployment.md before binding
# this anywhere else.
RAG_HOST=127.0.0.1
RAG_PORT=4735

# ============================================================
# Web App (Node.js/React)
# ============================================================

# Web server host and port
# Loopback by default; see docs/springfield-deployment.md before binding
# this anywhere else.
WEB_HOST=127.0.0.1
PORT=2393

# Path to your knowledge base directory
# Used when running the web server directly (not via `agn web`)
ZKB_PATH=./content-agn

# RAG backend URL (for the React frontend)
# Only needed if RAG backend runs on a different host/port
VITE_RAG_API_URL=http://localhost:4735

# ============================================================
# Governance (Phase 2 single-operator trust profile)
# Optional: leave unset to run without governance auth (unchanged
# pre-Phase-2 behavior). Set ALL reviewer/processor variables together,
# or startup fails closed. Never commit real secrets here - use your
# actual .env (gitignored) or `agn auth store-reviewer-secret`.
# ============================================================

# Stable reviewer id and display name
GOVERNANCE_REVIEWER_ID=
GOVERNANCE_REVIEWER_DISPLAY_NAME=

# Reviewer secret: >=32 bytes of entropy, e.g. `openssl rand -hex 32`
GOVERNANCE_REVIEWER_SECRET=

# Propose-only processor identity (used by the RAG backend's ingest calls)
GOVERNANCE_PROCESSOR_ID=
GOVERNANCE_PROCESSOR_SECRET=

# Exact origin the browser trust boundary is scoped to. Loopback by
# default; changing the host requires GOVERNANCE_PRIVATE_DEPLOYMENT=true
# below, per docs/springfield-deployment.md.
GOVERNANCE_PUBLIC_ORIGIN=http://127.0.0.1:2393

# Set to "true" only for a reviewed private-network deployment with TLS
# termination and explicit trusted proxies (see
# docs/springfield-deployment.md). Leave unset/false for local loopback use.
GOVERNANCE_PRIVATE_DEPLOYMENT=false
GOVERNANCE_TRUSTED_PROXY_HOSTS=

# Durable SQLite database backing the governed proposal queue, sqlite-engine
# namespaces (memory.*/operation.*), and web-owned operation-intent recovery
# bookkeeping. Required whenever governance is enabled -- startup fails
# closed without it.
GOVERNANCE_DB_PATH=./governed.sqlite

# JSON file listing the explicit Algerknown namespace mappings (dossier
# bindings) that determine which canonical.project.* namespaces are governed
# via git: { "dossiers": [{ "projectKey", "summaryId", "path" }, ...] }.
# Defaults to <ALGERKNOWN_ROOT>/.algerknown/governed-namespaces.json.
GOVERNANCE_NAMESPACE_BINDINGS_PATH=

# Version string recorded for the registered processor identity (the RAG
# backend). Cosmetic only; defaults to "rag-backend".
GOVERNANCE_PROCESSOR_VERSION=

# ============================================================
# CLI
# ============================================================

# Preferred editor for `agn edit` command
# Falls back to: EDITOR -> VISUAL -> vim
EDITOR=code

ALGERKNOWN_ROOT=/path/to/your/algerknown/content

# CLI reviewer secret for non-interactive/automation use. When unset, the
# CLI reads it from the OS keychain instead (see `agn auth --help`).
ALGERKNOWN_REVIEWER_SECRET=
